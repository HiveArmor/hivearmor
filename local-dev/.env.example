# =============================================================================
# UTMStack Local Development — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running:
#   cp .env.example .env
#   docker compose up -d
#
# NEVER commit .env with real values to version control.
# =============================================================================

# ── Docker image tag to pull ─────────────────────────────────────────────────
# Find latest tags at: https://github.com/hivearmor/hivearmor/releases
HIVEARMOR_TAG=v1.x.y-dev.N

# ── Server identity ───────────────────────────────────────────────────────────
# The hostname or IP address of this server, used for TLS certificate generation
# and email links. For local dev use: localhost
SERVER_NAME=localhost

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-strong-postgres-password-here

# ── OpenSearch ────────────────────────────────────────────────────────────────
# Must be at least 8 characters, contain uppercase, lowercase, digit, and symbol
OPENSEARCH_INITIAL_ADMIN_PASSWORD=YourStr0ng!Password

# ── Security ─────────────────────────────────────────────────────────────────
# Multi-factor authentication. Must be true for all non-development deployments.
# To skip TFA in a local dev stack only, override with APP_TFA_ENABLED=false in
# your local .env file. Never set false in a shared or production environment.
APP_TFA_ENABLED=true

# ── Inter-service authentication ──────────────────────────────────────────────
# Shared secret between backend, agent-manager, and event-processor.
# Generate with: openssl rand -hex 32
INTERNAL_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Event-processor inject endpoint key ──────────────────────────────────────
# API key required on the X-Inject-Key header to call POST :8090/v1/inject.
# Generate with: openssl rand -hex 32
EVENTPROCESSOR_INJECT_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Compliance Orchestrator ───────────────────────────────────────────────────
# Runs inside the eventprocessor container. Health endpoint: http://localhost:8094/health
# Evaluates HIPAA, PCI-DSS, ISO27001, NIST CSF, and SOC2 controls every 24 hours.
# Results are indexed into OpenSearch at: _v3_hive_log-compliance-evaluation
# Config is read from env vars: OPENSEARCH_HOST/PORT/USER/PASSWORD, BACKEND_URL, INTERNAL_KEY
# (all provided by docker-compose.override.yml — no additional variables needed)

# ── Encryption / JWT signing key ─────────────────────────────────────────────
# Used for encrypting sensitive configuration values at rest AND as the JWT
# signing key. Must be the same value across all services (backend, agent-manager).
# Changing this invalidates all active user sessions.
# Generate with: openssl rand -base64 64
ENCRYPTION_KEY=change-me-generate-with-openssl-rand-base64-64

# ── Neo4j - Security Knowledge Graph ─────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=localdev123!

# ── Kafka / Redpanda ─────────────────────────────────────────────────────────
# Internal broker address (service-to-service within Docker network)
KAFKA_BROKER=redpanda:9092
# External broker address (for tools running on the host, e.g. rpk CLI)
KAFKA_EXTERNAL_BROKER=localhost:19092
# Consumer group ID used by the event-processor
KAFKA_CONSUMER_GROUP=hivearmor-event-processor

# =============================================================================
# Notes:
#
# INTERNAL_KEY and ENCRYPTION_KEY must match across all services in the stack.
# Changing them after first start requires restarting ALL services simultaneously.
#
# POSTGRES_PASSWORD is used by: backend, agent-manager, user-auditor.
# All three databases (hivearmor, agentmanager, userauditor) share this password.
#
# After running `docker compose up -d`, the default admin credentials are:
#   Username: admin
#   Password: (printed to logs on first startup, stored in the backend container)
# =============================================================================
