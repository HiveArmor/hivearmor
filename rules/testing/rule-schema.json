{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hivearmor/event-processor/rules/testing/rule-schema.json",
  "title": "HiveArmor Correlation Rule",
  "description": "Schema for a single HiveArmor detection rule or a list of rules in one YAML file.",
  "oneOf": [
    { "$ref": "#/$defs/rule" },
    {
      "type": "array",
      "items": { "$ref": "#/$defs/rule" },
      "minItems": 1
    }
  ],
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["name", "dataTypes", "category", "impact"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable rule name shown in alerts."
        },
        "dataTypes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "description": "Log source types this rule applies to (e.g. linux, wineventlog, aws)."
        },
        "category": {
          "type": "string",
          "minLength": 1,
          "description": "MITRE ATT&CK tactic or detection category.",
          "examples": [
            "Credential Access",
            "Defense Evasion",
            "Lateral Movement",
            "Privilege Escalation",
            "Persistence",
            "Exfiltration",
            "Command and Control",
            "Execution",
            "Discovery",
            "Collection",
            "Initial Access",
            "Impact",
            "Reconnaissance",
            "Resource Development",
            "Threat Detection"
          ]
        },
        "technique": {
          "type": "string",
          "description": "MITRE ATT&CK technique ID and name (e.g. T1110 - Brute Force)."
        },
        "impact": {
          "type": "object",
          "required": ["confidentiality", "integrity", "availability"],
          "properties": {
            "confidentiality": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3,
              "description": "0=none, 1=low, 2=medium, 3=high"
            },
            "integrity": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3
            },
            "availability": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3
            }
          },
          "additionalProperties": false
        },
        "adversary": {
          "type": "string",
          "enum": ["origin", "target"],
          "description": "Which side of the log event is the adversary."
        },
        "description": {
          "type": "string",
          "description": "Plain-text description of what the rule detects and recommended next steps."
        },
        "references": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "description": "External references (MITRE ATT&CK pages, vendor advisories, etc.)."
        },
        "where": {
          "type": "string",
          "minLength": 1,
          "description": "CEL expression evaluated against each event. Required unless 'riskScore' or 'afterEvents' is present."
        },
        "riskScore": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "description": "Static risk score override; used in place of 'where' for feed-based rules."
        },
        "afterEvents": {
          "type": "array",
          "items": { "$ref": "#/$defs/afterEvent" },
          "minItems": 1,
          "description": "Correlation queries run against historical events once 'where' matches."
        },
        "groupBy": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Fields used to group correlated events (e.g. origin.ip, origin.user)."
        },
        "sequence": {
          "type": "array",
          "items": { "$ref": "#/$defs/sequenceStep" },
          "minItems": 2,
          "description": "Ordered sequence of sub-rules that must all fire to generate an alert."
        }
      },
      "additionalProperties": true,
      "allOf": [
        {
          "description": "At least one of where / riskScore / afterEvents / sequence must be present.",
          "anyOf": [
            { "required": ["where"] },
            { "required": ["riskScore"] },
            { "required": ["afterEvents"] },
            { "required": ["sequence"] }
          ]
        }
      ]
    },
    "afterEvent": {
      "type": "object",
      "required": ["indexPattern", "with"],
      "properties": {
        "indexPattern": {
          "type": "string",
          "minLength": 1,
          "description": "OpenSearch index pattern to query (e.g. v11-log-linux-*)."
        },
        "with": {
          "type": "array",
          "items": { "$ref": "#/$defs/afterEventFilter" },
          "minItems": 1
        },
        "minCount": {
          "type": "integer",
          "minimum": 1,
          "description": "Minimum number of matching historical events required."
        },
        "timeWindow": {
          "type": "string",
          "description": "Lookback window (e.g. 5m, 1h, 24h)."
        }
      },
      "additionalProperties": true
    },
    "afterEventFilter": {
      "type": "object",
      "required": ["field", "operator", "value"],
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "operator": {
          "type": "string",
          "enum": [
            "filter_term",
            "filter_match",
            "filter_range_gte",
            "filter_range_lte",
            "filter_exists"
          ]
        },
        "value": { "type": "string" }
      },
      "additionalProperties": false
    },
    "sequenceStep": {
      "type": "object",
      "required": ["where"],
      "properties": {
        "where": {
          "type": "string",
          "minLength": 1,
          "description": "CEL expression for this step."
        },
        "within": {
          "type": "string",
          "description": "Time window within which this step must occur after the previous (e.g. 10m)."
        }
      },
      "additionalProperties": true
    }
  }
}
