{
  "enabled": true,
  "name": "Frontend Lint + Test on Save",
  "description": "When any frontend TypeScript, HTML, or SCSS source file is saved, runs ESLint (angular-eslint) on the full project. Uses NODE_OPTIONS with --max_old_space_size=8192 (8 GB heap required by Angular 17 build chain) and --openssl-legacy-provider (required because Node 20 + OpenSSL 3 disables MD4 hashing used by webpack). The --max-warnings=0 flag is intentionally not set — the baseline has 268 pre-existing lint issues; the hook reports them but does not fail on warnings, only on errors introduced by the current save.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "frontend/src/**/*.ts",
      "frontend/src/**/*.html",
      "frontend/src/**/*.scss"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "sh -c 'cd frontend && NODE_OPTIONS=\"--max_old_space_size=8192 --openssl-legacy-provider\" npm run lint 2>&1; exit 0'",
    "timeout": 120
  }
}
