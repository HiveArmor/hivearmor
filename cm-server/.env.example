# =============================================================================
# CM Server — environment variables
# Copy to .env before running: cp .env.example .env
# NEVER commit .env with real values.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-strong-postgres-password-here

# ── Registration HMAC salt ────────────────────────────────────────────────────
# Must match the CM_ENCRYPT_SALT baked into agent/collector binaries at build
# time via ldflags. Leave empty in dev to skip signature verification.
# Generate: openssl rand -hex 32
CM_ENCRYPT_SALT=

# ── Version signature verification ───────────────────────────────────────────
# RSA-4096 public key (PEM) for verifying version payloads published by CI.
# Generate keypair:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:4096 -out cm_sign_private.pem
#   openssl rsa -pubout -in cm_sign_private.pem -out cm_sign_public.pem
# Store the private key in your password manager and add it to GitHub Secrets
# as CM_SIGN_PRIVATE_KEY. Paste the public PEM below (leave empty to skip).
CM_SIGN_PUBLIC_KEY=
