<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="20260705007-1" author="armorSight">
        <createTable tableName="utm_threat_feed">
            <column name="id" type="VARCHAR(50)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(100)"/>
            <column name="source" type="VARCHAR(500)"/>
            <column name="last_updated" type="TIMESTAMPTZ"/>
            <column name="ioc_count" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="active">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(1000)"/>
            <column name="created_at" type="TIMESTAMPTZ"/>
        </createTable>
        <createIndex tableName="utm_threat_feed" indexName="idx_utm_threat_feed_enabled">
            <column name="enabled"/>
        </createIndex>
    </changeSet>

