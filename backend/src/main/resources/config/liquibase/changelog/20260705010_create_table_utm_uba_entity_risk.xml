<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.9.xsd">

    <!-- Entity risk table: one row per user/device tracked -->
    <changeSet id="20260705010-1" author="armorsight">
        <createTable tableName="utm_uba_entity_risk">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="entity_id" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_type" type="VARCHAR(20)" defaultValue="user">
                <!-- user | host | service -->
                <constraints nullable="false"/>
            </column>
            <column name="display_name" type="VARCHAR(200)"/>
            <column name="department" type="VARCHAR(100)"/>
            <column name="role" type="VARCHAR(100)"/>
            <column name="risk_score" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="prev_risk_score" type="INT" defaultValueNumeric="0"/>
            <column name="risk_level" type="VARCHAR(20)" defaultValue="low">
                <!-- low | medium | high | critical -->
                <constraints nullable="false"/>
            </column>
            <column name="anomaly_count" type="INT" defaultValueNumeric="0"/>
            <column name="alert_count" type="INT" defaultValueNumeric="0"/>
            <column name="last_seen" type="TIMESTAMPTZ"/>
            <column name="first_seen" type="TIMESTAMPTZ"/>
            <column name="factors_json" type="TEXT"/>
            <!-- JSON array of contributing risk factor strings -->
            <column name="risk_trend_json" type="TEXT"/>
            <!-- JSON array of {date, score} for sparkline -->
            <column name="watchlisted" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="status" type="VARCHAR(20)" defaultValue="active"/>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()"/>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()"/>
        </createTable>
    </changeSet>

    <changeSet id="20260705010-2" author="armorsight">
        <createIndex tableName="utm_uba_entity_risk" indexName="idx_uba_entity_risk_score">
            <column name="risk_score"/>
        </createIndex>
        <createIndex tableName="utm_uba_entity_risk" indexName="idx_uba_entity_risk_level">
            <column name="risk_level"/>
        </createIndex>
        <createIndex tableName="utm_uba_entity_risk" indexName="idx_uba_entity_type">
            <column name="entity_type"/>
        </createIndex>
        <addUniqueConstraint tableName="utm_uba_entity_risk" columnNames="entity_id,entity_type"
            constraintName="uq_uba_entity_id_type"/>
    </changeSet>

