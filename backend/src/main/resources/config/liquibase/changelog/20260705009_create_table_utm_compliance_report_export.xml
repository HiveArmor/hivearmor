<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.9.xsd">

    <changeSet id="20260705009-1" author="armorsight">
        <createTable tableName="utm_compliance_report_export">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="report_name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="standard" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="Pending">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="pdf_path" type="TEXT"/>
        </createTable>
    </changeSet>

    <changeSet id="20260705009-2" author="armorsight">
        <createIndex tableName="utm_compliance_report_export" indexName="idx_compliance_export_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
