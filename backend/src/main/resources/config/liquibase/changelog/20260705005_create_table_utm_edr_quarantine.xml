<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260705005-1" author="armorsight">
        <createTable tableName="utm_edr_quarantine">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="agent_id" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="hostname" type="VARCHAR(200)"/>
            <column name="file_path" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="file_hash" type="VARCHAR(128)"/>
            <column name="file_size" type="BIGINT"/>
            <column name="original_path" type="TEXT"/>
            <column name="quarantine_path" type="TEXT"/>
            <column name="reason" type="VARCHAR(500)"/>
            <column name="status" type="VARCHAR(20)" defaultValue="QUARANTINED">
                <constraints nullable="false"/>
            </column>
            <column name="quarantined_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="restored_at" type="TIMESTAMPTZ"/>
            <column name="actioned_by" type="VARCHAR(100)"/>
            <column name="edr_event_id" type="BIGINT"/>
        </createTable>
        <createIndex tableName="utm_edr_quarantine" indexName="idx_edr_quarantine_agent_id">
            <column name="agent_id"/>
        </createIndex>
        <createIndex tableName="utm_edr_quarantine" indexName="idx_edr_quarantine_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
